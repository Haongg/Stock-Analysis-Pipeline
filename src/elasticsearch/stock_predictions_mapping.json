{
  "settings": {
    "number_of_shards": 1,
    "number_of_replicas": 0,
    "index.codec": "best_compression",
    "refresh_interval": "30s"
  },
  "mappings": {
    "properties": {
      "@timestamp": {
        "type": "date",
        "format": "strict_date_optional_time||yyyy-MM-dd'T'HH:mm:ss.SSSZZ"
      },
      "ticker": {
        "type": "keyword"
      },
      "predicted_close": {
        "type": "float"
      },
      "actual_close": {
        "type": "float"
      },
      "model_version": {
        "type": "keyword"
      },
      "prediction_date": {
        "type": "date",
        "format": "strict_date_optional_time||yyyy-MM-dd'T'HH:mm:ss.SSSZZ"
      },
      "confidence": {
        "type": "float"
      }
    }
  }
}