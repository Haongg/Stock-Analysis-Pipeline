{
  "settings": {
    "number_of_shards": 1,
    "number_of_replicas": 0,
    "index.codec": "best_compression",
    "refresh_interval": "30s"
  },
  "mappings": {
    "properties": {
      "@timestamp": {
        "type": "date",
        "format": "strict_date_optional_time||yyyy-MM-dd'T'HH:mm:ss.SSSZZ"
      },
      "ticker": {
        "type": "keyword"
      },
      "open": {
        "type": "float"
      },
      "high": {
        "type": "float"
      },
      "low": {
        "type": "float"
      },
      "close": {
        "type": "float"
      },
      "volume": {
        "type": "long"
      },
      "sma_10": {
        "type": "float"
      },
      "sma_20": {
        "type": "float"
      },
      "sma_50": {
        "type": "float"
      },
      "ema_20": {
        "type": "float"
      },
      "rsi": {
        "type": "float"
      },
      "macd": {
        "type": "float"
      },
      "macd_signal": {
        "type": "float"
      },
      "macd_hist": {
        "type": "float"
      },
      "volatility": {
        "type": "float"
      },
      "daily_return": {
        "type": "float"
      },
      "close_lag_1": {
        "type": "float"
      },
      "close_lag_5": {
        "type": "float"
      },
      "ingested_at": {
        "type": "date",
        "format": "strict_date_optional_time||yyyy-MM-dd'T'HH:mm:ss.SSSZZ"
      }
    }
  }
}